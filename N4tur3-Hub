    Callback = function(Value) instaPromptsEnabled = Value end,
}, "InstaToggle")

-- Respawn support
LocalPlayer.CharacterAdded:Connect(function()
    task.wait(0.5)
    if tsunamiGod then SetGodmode(true) end
    if noclipEnabled then setNoclip(true) end
    if infZoomEnabled then setInfZoom(true) end
    if flyEnabled then setFly(true) end
end)

print("✅ N4tur3 Hub loaded with Mobile Fly!")
]])()