}, "DupeGroup")

local dupeEnabled = false

task.spawn(function()
    while true do
        if dupeEnabled then
            local char = LocalPlayer.Character
            local tool = char and char:FindFirstChildOfClass("Tool")
            if tool then
                tool.Parent = LocalPlayer.Backpack
                task.wait(0.01)
                tool.Parent = char
            end
        end
        task.wait(0.05)
    end
end)

DupeGroup:CreateToggle({
